{
  "expo": {
    "name": "Go Goree Clients",
    "slug": "go-goree-clients",
    "version": "1.0.0",
    "scheme": "gogoreeclients",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sn.gogoree.clients"
    },
    "android": {
      "package": "sn.gogoree.clients",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Go Goree utilise Face ID pour vous reconnecter rapidement et en toute sécurité."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Go Goree a besoin d'accéder à vos photos pour envoyer vos documents.",
          "cameraPermission": "Go Goree a besoin d'accéder à votre caméra pour photographier vos documents."
        }
      ],
      "expo-web-browser",
      "expo-notifications"
    ]
  }
}
